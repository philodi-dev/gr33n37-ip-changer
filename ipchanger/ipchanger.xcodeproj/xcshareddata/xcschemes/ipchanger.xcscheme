<?xml version="1.0" encoding="UTF-8"?>
<Scheme
   LastUpgradeVersion = "2620"
   version = "1.7">
   <BuildAction
      parallelizeBuildables = "YES"
      buildImplicitDependencies = "YES">
      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Install prefPane (after sign)"
               scriptText = "set -e
# Scheme scripts may not export all Xcode vars; try several sources (same as install_prefpane.sh).
WRAP=&quot;${WRAPPER_NAME:-ipchanger.prefPane}&quot;
SRC=&quot;&quot;
if [ -n &quot;${CODESIGNING_FOLDER_PATH}&quot; ] &amp;&amp; [ -d &quot;${CODESIGNING_FOLDER_PATH}/Contents/MacOS&quot; ]; then
  SRC=&quot;${CODESIGNING_FOLDER_PATH}&quot;
elif [ -n &quot;${TARGET_BUILD_DIR}&quot; ] &amp;&amp; [ -n &quot;$WRAP&quot; ]; then
  SRC=&quot;${TARGET_BUILD_DIR}/${WRAP}&quot;
elif [ -n &quot;${BUILT_PRODUCTS_DIR}&quot; ] &amp;&amp; [ -n &quot;$WRAP&quot; ]; then
  SRC=&quot;${BUILT_PRODUCTS_DIR}/${WRAP}&quot;
fi
if [ -z &quot;$SRC&quot; ] || [ &quot;$SRC&quot; = &quot;/&quot; ] || [ ! -d &quot;$SRC/Contents/MacOS&quot; ]; then
  echo &quot;error: Install prefPane: no valid bundle (tried CODESIGNING_FOLDER_PATH, TARGET_BUILD_DIR, BUILT_PRODUCTS_DIR; wrap=$WRAP; got \&quot;$SRC\&quot;)&quot; &gt;&amp;2
  exit 1
fi
mkdir -p &quot;${HOME}/Library/PreferencePanes&quot;
rm -rf &quot;${HOME}/Library/PreferencePanes/ipchanger.prefPane&quot;
cp -R &quot;$SRC&quot; &quot;${HOME}/Library/PreferencePanes/ipchanger.prefPane&quot;
echo &quot;Installed: ${HOME}/Library/PreferencePanes/ipchanger.prefPane&quot;
echo &quot;Quit System Settings (Cmd+Q), reopen, search for IP Changer.&quot;
"
               shellToInvoke = "/bin/sh">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "AED709A12F832B4D00E70440"
                     BuildableName = "ipchanger.prefPane"
                     BlueprintName = "ipchanger"
                     ReferencedContainer = "container:ipchanger.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
      <BuildActionEntries>
         <BuildActionEntry
            buildForTesting = "YES"
            buildForRunning = "YES"
            buildForProfiling = "YES"
            buildForArchiving = "YES"
            buildForAnalyzing = "YES">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "AED709A12F832B4D00E70440"
               BuildableName = "ipchanger.prefPane"
               BlueprintName = "ipchanger"
               ReferencedContainer = "container:ipchanger.xcodeproj">
            </BuildableReference>
         </BuildActionEntry>
      </BuildActionEntries>
   </BuildAction>
